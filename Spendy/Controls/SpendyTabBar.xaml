<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Spendy.Controls.SpendyTabBar"
             x:Name="RootTabBar"
             HeightRequest="86">
    <!-- Full-width navbar artwork from /images (active bubble baked into each strip PNG). -->
    <Grid x:Name="NavRoot" VerticalOptions="End" RowDefinitions="Auto">
        <Image x:Name="StripImage"
               Aspect="AspectFit"
               VerticalOptions="End"
               HorizontalOptions="Fill"
               HeightRequest="86"
               InputTransparent="True" />
        <Grid x:Name="TapGrid"
              ColumnDefinitions="*,*,*,*"
              HeightRequest="86"
              VerticalOptions="End"
              BackgroundColor="Transparent">
            <Grid Grid.Column="0" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </Grid.GestureRecognizers>
            </Grid>
            <Grid Grid.Column="1" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnStatsTapped" />
                </Grid.GestureRecognizers>
            </Grid>
            <Grid Grid.Column="2" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSavingsTapped" />
                </Grid.GestureRecognizers>
            </Grid>
            <Grid Grid.Column="3" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSettingsTapped" />
                </Grid.GestureRecognizers>
            </Grid>
        </Grid>
    </Grid>
</ContentView>
