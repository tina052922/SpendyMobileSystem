<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Spendy.ViewModels"
             x:Class="Spendy.Views.SignUpPage"
             x:DataType="vm:SignUpViewModel"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F3F4F6">
    <Grid RowDefinitions="Auto,*">
        <!-- Reference: deep navy header, white title, left-aligned -->
        <Grid Grid.Row="0"
              Padding="24,56,24,28"
              MinimumHeightRequest="168"
              BackgroundColor="#001F54">
            <Label Text="Create Your Account"
                   FontFamily="OpenSansSemibold"
                   FontSize="28"
                   TextColor="White"
                   HorizontalOptions="Start"
                   VerticalOptions="Start" />
        </Grid>

        <ScrollView Grid.Row="1" Margin="0,-20,0,0">
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="24,28,24,36">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24,24,0,0" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="18">
                    <Label Text="First name"
                           TextColor="#0F172A"
                           FontFamily="OpenSansSemibold"
                           FontSize="13" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="White"
                                Stroke="#D1D5DB"
                                StrokeThickness="1"
                                Padding="14,0"
                                HeightRequest="48">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Entry Placeholder="First name"
                                   Text="{Binding FirstName}"
                                   BackgroundColor="Transparent"
                                   TextColor="#0F172A"
                                   PlaceholderColor="#9CA3AF"
                                   VerticalOptions="Center" />
                        </Border>
                        <Border Grid.Column="1"
                                BackgroundColor="White"
                                Stroke="#D1D5DB"
                                StrokeThickness="1"
                                Padding="14,0"
                                HeightRequest="48">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Entry Placeholder="Last name"
                                   Text="{Binding LastName}"
                                   BackgroundColor="Transparent"
                                   TextColor="#0F172A"
                                   PlaceholderColor="#9CA3AF"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <Label Text="Birthday"
                           TextColor="#0F172A"
                           FontFamily="OpenSansSemibold"
                           FontSize="13" />
                    <Border BackgroundColor="White"
                            Stroke="#D1D5DB"
                            StrokeThickness="1"
                            Padding="12,0,14,0"
                            HeightRequest="48">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <DatePicker Date="{Binding Birthday, Mode=TwoWay}"
                                    MaximumDate="{Binding MaximumBirthdayDate}"
                                    Format="MMMM dd, yyyy"
                                    FontSize="15"
                                    TextColor="#0F172A"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center" />
                    </Border>

                    <Label Text="Email address"
                           TextColor="#0F172A"
                           FontFamily="OpenSansSemibold"
                           FontSize="13" />
                    <Border BackgroundColor="White"
                            Stroke="#D1D5DB"
                            StrokeThickness="1"
                            Padding="14,0"
                            HeightRequest="48">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry Placeholder="Enter your email"
                               Keyboard="Email"
                               Text="{Binding Email}"
                               BackgroundColor="Transparent"
                               TextColor="#0F172A"
                               PlaceholderColor="#9CA3AF"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="Password"
                           TextColor="#0F172A"
                           FontFamily="OpenSansSemibold"
                           FontSize="13" />
                    <Border BackgroundColor="White"
                            Stroke="#D1D5DB"
                            StrokeThickness="1"
                            HeightRequest="48"
                            Padding="12,0,10,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                            <Entry x:Name="PasswordEntry"
                                   Grid.Column="0"
                                   Text="{Binding Password}"
                                   Placeholder="Password"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   TextColor="#0F172A"
                                   PlaceholderColor="#9CA3AF"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTogglePasswordEye" />
                                </Border.GestureRecognizers>
                                <Image x:Name="PasswordEyeImage"
                                       Source="unhide.png"
                                       Aspect="AspectFit"
                                       WidthRequest="22"
                                       HeightRequest="22"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       InputTransparent="True" />
                            </Border>
                        </Grid>
                    </Border>

                    <Label Text="Confirm password"
                           TextColor="#0F172A"
                           FontFamily="OpenSansSemibold"
                           FontSize="13" />
                    <Border BackgroundColor="White"
                            Stroke="#D1D5DB"
                            StrokeThickness="1"
                            Padding="14,0"
                            HeightRequest="48">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry Placeholder="Confirm password"
                               Text="{Binding ConfirmPassword}"
                               IsPassword="True"
                               BackgroundColor="Transparent"
                               TextColor="#0F172A"
                               PlaceholderColor="#9CA3AF"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="{Binding PasswordStrengthLabel}"
                           FontSize="12"
                           FontFamily="OpenSansSemibold"
                           TextColor="{Binding PasswordStrengthColor}" />

                    <HorizontalStackLayout Spacing="10" Margin="0,2,0,0">
                        <CheckBox Color="#2563EB"
                                  IsChecked="{Binding TermsAccepted}" />
                        <Label VerticalOptions="Center"
                               FontSize="13"
                               TextColor="#374151">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="I agree to the " />
                                    <Span Text="Terms &amp; Conditions"
                                          TextColor="#2563EB"
                                          FontAttributes="Bold"
                                          TextDecorations="Underline">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTerms" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </HorizontalStackLayout>

                    <Button Text="Sign up"
                            BackgroundColor="#001F54"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            CornerRadius="14"
                            HeightRequest="52"
                            Margin="0,8,0,0"
                            Command="{Binding SignUpCommand}" />

                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10" Margin="0,4">
                        <BoxView Grid.Column="0" HeightRequest="1" Color="#E5E7EB" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Or" TextColor="#9CA3AF" FontSize="13" />
                        <BoxView Grid.Column="2" HeightRequest="1" Color="#E5E7EB" VerticalOptions="Center" />
                    </Grid>

                    <Button Text="Sign up with Google"
                            ImageSource="google.png"
                            ContentLayout="Left,12"
                            BackgroundColor="White"
                            TextColor="#0F172A"
                            BorderColor="#D1D5DB"
                            BorderWidth="1"
                            CornerRadius="12"
                            FontSize="15"
                            HeightRequest="52"
                            Clicked="OnGoogle" />

                    <VerticalStackLayout Spacing="6" Margin="0,8,0,0">
                        <Label HorizontalTextAlignment="Center"
                               FontSize="14"
                               TextColor="#6B7280">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Already have an account? " />
                                    <Span Text="Sign in"
                                          TextColor="#2563EB"
                                          FontAttributes="Bold">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSignIn" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>
