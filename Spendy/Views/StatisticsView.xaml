<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Spendy.Views.StatisticsView">
    <ScrollView BackgroundColor="{StaticResource SpendyPageBg}">
        <VerticalStackLayout x:Name="StatsRoot"
                             Spacing="0"
                             Padding="0,0,0,120">
            <!-- Top row: avatar + bell (light background) -->
            <Grid Padding="24,16,24,10"
                  ColumnDefinitions="Auto,*,Auto">
                <Border WidthRequest="44"
                        HeightRequest="44"
                        StrokeThickness="0"
                        BackgroundColor="#1AFFFFFF">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Image Source="{Binding ProfilePhoto}" Aspect="AspectFill" />
                </Border>
                <Border Grid.Column="2"
                        WidthRequest="46"
                        HeightRequest="46"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="9">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <ImageButton Source="darkbluenotificon.png"
                                 BackgroundColor="Transparent"
                                 Aspect="AspectFit"
                                 Command="{Binding OpenNotificationsCommand}" />
                </Border>
            </Grid>

            <!-- Balance card -->
            <Border Margin="24,0,24,14"
                    StrokeThickness="0"
                    Padding="16"
                    HeightRequest="90">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0B1B3A" Offset="0" />
                        <GradientStop Color="#01143D" Offset="0.55" />
                        <GradientStop Color="#0335A3" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- glossy highlight (matches reference card streak) -->
                    <Border HorizontalOptions="End"
                            VerticalOptions="Center"
                            WidthRequest="150"
                            HeightRequest="120"
                            Margin="0,-28,-36,0"
                            StrokeThickness="0"
                            Opacity="0.45"
                            Rotation="-18">
                        <Border.StrokeShape>
                            <Ellipse />
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#66FFFFFF" Offset="0" />
                                <GradientStop Color="#00FFFFFF" Offset="0.65" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Available balance"
                               TextColor="#B3FFFFFF"
                               FontSize="14" />
                        <Label Text="{Binding AvailableBalance}"
                               TextColor="White"
                               FontFamily="OpenSansSemibold"
                               FontSize="34" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Toggle pills -->
            <Grid Padding="24,0,24,14"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="14">
                <Button Text="Expenses"
                        Command="{Binding SelectExpenseCommand}"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        CornerRadius="26"
                        HeightRequest="52"
                        BackgroundColor="{Binding ExpenseButtonBackground}" />
                <Button Grid.Column="1"
                        Text="Income"
                        Command="{Binding SelectIncomeCommand}"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        CornerRadius="26"
                        HeightRequest="52"
                        BackgroundColor="{Binding IncomeButtonBackground}" />
            </Grid>

            <!-- Month label + calendar button -->
            <Grid Padding="24,0,24,8"
                  ColumnDefinitions="*,Auto,*">
                <BoxView Color="Transparent" />
                <HorizontalStackLayout Grid.Column="1"
                                       Spacing="8"
                                       VerticalOptions="Center">
                    <BoxView WidthRequest="8"
                             HeightRequest="8"
                             CornerRadius="4"
                             BackgroundColor="{StaticResource SpendyNavy}"
                             VerticalOptions="Center" />
                    <Label Text="{Binding MonthLabel}"
                           TextColor="#667085"
                           FontSize="12"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
                <Border Grid.Column="2"
                        WidthRequest="42"
                        HeightRequest="42"
                        HorizontalOptions="End"
                        BackgroundColor="{StaticResource SpendyNavy}"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Image Source="calendar.png"
                           WidthRequest="20"
                           HeightRequest="20"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- Chart with y-axis + gridlines -->
            <Grid Padding="24,0,24,14"
                  ColumnDefinitions="42,*"
                  HeightRequest="220">
                <!-- Y axis labels -->
                <Grid Grid.Column="0"
                      RowDefinitions="Auto,*,*,*,*,Auto"
                      Padding="0,10,6,16">
                    <Label Grid.Row="1" Text="{Binding YAxis200}" FontSize="10" TextColor="#98A2B3" HorizontalTextAlignment="End" />
                    <Label Grid.Row="2" Text="{Binding YAxis150}" FontSize="10" TextColor="#98A2B3" HorizontalTextAlignment="End" />
                    <Label Grid.Row="3" Text="{Binding YAxis100}" FontSize="10" TextColor="#98A2B3" HorizontalTextAlignment="End" />
                    <Label Grid.Row="4" Text="{Binding YAxis50}"  FontSize="10" TextColor="#98A2B3" HorizontalTextAlignment="End" />
                    <Label Grid.Row="5" Text="{Binding YAxis0}"   FontSize="10" TextColor="#98A2B3" HorizontalTextAlignment="End" />
                </Grid>

                <!-- Chart area -->
                <Grid Grid.Column="1"
                      RowDefinitions="*,Auto"
                      Padding="0,10,0,0">
                    <Grid Grid.Row="0" RowDefinitions="*,*,*,*,*">
                        <BoxView Grid.Row="0" HeightRequest="1" VerticalOptions="Start" BackgroundColor="#D0D5DD" />
                        <BoxView Grid.Row="1" HeightRequest="1" VerticalOptions="Start" BackgroundColor="#D0D5DD" />
                        <BoxView Grid.Row="2" HeightRequest="1" VerticalOptions="Start" BackgroundColor="#D0D5DD" />
                        <BoxView Grid.Row="3" HeightRequest="1" VerticalOptions="Start" BackgroundColor="#D0D5DD" />
                        <BoxView Grid.Row="4" HeightRequest="1" VerticalOptions="Start" BackgroundColor="#D0D5DD" />
                    </Grid>

                    <CollectionView Grid.Row="0"
                                    ItemsSource="{Binding Bars}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid WidthRequest="26"
                                      HeightRequest="190"
                                      RowDefinitions="*,Auto"
                                      Padding="0,0,0,6">
                                    <BoxView Grid.Row="0"
                                             WidthRequest="16"
                                             HeightRequest="{Binding BarHeight}"
                                             HorizontalOptions="Center"
                                             VerticalOptions="End"
                                             Color="#01143D"
                                             CornerRadius="10" />
                                    <Label Grid.Row="1"
                                           Text="{Binding Day}"
                                           FontSize="10"
                                           TextColor="#667085"
                                           HorizontalTextAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Grid>

            <!-- Category breakdown -->
            <VerticalStackLayout Padding="24,0,24,0" Spacing="10">
                <Label Text="{Binding ChartTitle}"
                       TextColor="{StaticResource SpendyNavy}"
                       FontAttributes="Bold"
                       FontSize="16" />

                <Label Text="No spending data for this month yet."
                       IsVisible="{Binding ShowCategoryEmpty}"
                       TextColor="#667085"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       Margin="0,8,0,16" />

                <CollectionView ItemsSource="{Binding Categories}"
                                IsVisible="{Binding HasCategoryBreakdown}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                    StrokeThickness="0"
                                    Padding="14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <Border WidthRequest="36"
                                            HeightRequest="36"
                                            BackgroundColor="{StaticResource SpendyNavy}"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Icon}"
                                               FontSize="18"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                    <Label Grid.Column="1"
                                           Text="{Binding Name}"
                                           TextColor="{StaticResource SpendyNavy}"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="2"
                                           Text="{Binding FormattedAmount}"
                                           TextColor="{StaticResource SpendyNavy}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentView>
