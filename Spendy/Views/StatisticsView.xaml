<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Spendy.Views.StatisticsView"
             BackgroundColor="{StaticResource SpendyPageBg}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0,0,0,100">

            <!-- Top Navigation Bar -->
            <Grid Padding="24,16,24,12"
                  ColumnDefinitions="Auto,*,Auto">

                <!-- Avatar -->
                <Border WidthRequest="44" HeightRequest="44"
                        StrokeThickness="0"
                        BackgroundColor="#1AFFFFFF"
                        HorizontalOptions="Start">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Image Source="{Binding ProfilePhoto}" Aspect="AspectFill" />
                </Border>

                <!-- Notification Bell -->
                <Border Grid.Column="2"
                        WidthRequest="46" HeightRequest="46"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="8">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <ImageButton Source="darkbluenotificon.png"
                                 BackgroundColor="Transparent"
                                 Aspect="AspectFit"
                                 Command="{Binding OpenNotificationsCommand}" />
                </Border>
            </Grid>

            <!-- Available Balance Card -->
            <Border Margin="24,0,24,20"
                    HeightRequest="98"
                    StrokeThickness="0"
                    Padding="20,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0B1B3A" Offset="0" />
                        <GradientStop Color="#01143D" Offset="0.5" />
                        <GradientStop Color="#0335A3" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <!-- Glossy highlight effect -->
                <Border HorizontalOptions="End" VerticalOptions="Center"
                        WidthRequest="160" HeightRequest="130"
                        Margin="0,-35,-40,0"
                        StrokeThickness="0"
                        Opacity="0.35"
                        Rotation="-20">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#88FFFFFF" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="0.7" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Available balance"
                           TextColor="#B3FFFFFF"
                           FontSize="14.5" />
                    <Label Text="{Binding AvailableBalance}"
                           TextColor="White"
                           FontFamily="OpenSansSemibold"
                           FontSize="36"
                           LineHeight="1.1" />
                </VerticalStackLayout>
            </Border>

            <!-- Expenses / Income Toggle -->
            <Grid Padding="24,0,24,20"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="12">

                <Button Text="Expenses"
                        Command="{Binding SelectExpenseCommand}"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="17"
                        CornerRadius="30"
                        HeightRequest="54"
                        BackgroundColor="{Binding ExpenseButtonBackground}" />

                <Button Grid.Column="1"
                        Text="Income"
                        Command="{Binding SelectIncomeCommand}"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="17"
                        CornerRadius="30"
                        HeightRequest="54"
                        BackgroundColor="{Binding IncomeButtonBackground}" />
            </Grid>

            <!-- Month + Calendar -->
            <Grid Padding="24,0,24,12"
                  ColumnDefinitions="*,Auto,*">

                <HorizontalStackLayout Grid.Column="1"
                                       Spacing="8"
                                       VerticalOptions="Center">
                    <BoxView WidthRequest="8" HeightRequest="8"
                             CornerRadius="4"
                             BackgroundColor="{StaticResource SpendyNavy}"
                             VerticalOptions="Center" />
                    <Label Text="{Binding MonthLabel}"
                           TextColor="#667085"
                           FontSize="13"
                           FontAttributes="Medium"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Calendar Button -->
                <Border Grid.Column="2"
                        WidthRequest="44" HeightRequest="44"
                        BackgroundColor="{StaticResource SpendyNavy}"
                        StrokeThickness="0"
                        HorizontalOptions="End">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Image Source="calendar.png"
                           WidthRequest="22" HeightRequest="22"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- Bar Chart -->
            <Grid Padding="24,0,24,20"
                  ColumnDefinitions="42,*"
                  HeightRequest="235">

                <!-- Y-Axis Labels -->
                <Grid Grid.Column="0"
                      RowDefinitions="*,*,*,*,*"
                      Padding="0,12,8,20">
                    <Label Grid.Row="0" Text="{Binding YAxis200}" FontSize="10.5" TextColor="#98A2B3" HorizontalTextAlignment="End" VerticalOptions="Start" />
                    <Label Grid.Row="1" Text="{Binding YAxis150}" FontSize="10.5" TextColor="#98A2B3" HorizontalTextAlignment="End" VerticalOptions="Center" />
                    <Label Grid.Row="2" Text="{Binding YAxis100}" FontSize="10.5" TextColor="#98A2B3" HorizontalTextAlignment="End" VerticalOptions="Center" />
                    <Label Grid.Row="3" Text="{Binding YAxis50}"  FontSize="10.5" TextColor="#98A2B3" HorizontalTextAlignment="End" VerticalOptions="Center" />
                    <Label Grid.Row="4" Text="{Binding YAxis0}"  FontSize="10.5" TextColor="#98A2B3" HorizontalTextAlignment="End" VerticalOptions="End" />
                </Grid>

                <!-- Chart Area -->
                <Grid Grid.Column="1" Padding="0,12,0,0">
                    <!-- Horizontal Grid Lines -->
                    <VerticalStackLayout Spacing="0" VerticalOptions="Fill">
                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" />
                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" />
                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" />
                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" />
                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" />
                    </VerticalStackLayout>

                    <!-- Bars -->
                    <CollectionView ItemsSource="{Binding Bars}"
                                    SelectionMode="None"
                                    VerticalOptions="Fill">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               ItemSpacing="7" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid WidthRequest="27" HeightRequest="195"
                                      RowDefinitions="*,Auto"
                                      Padding="0,0,0,4">
                                    <BoxView Grid.Row="0"
                                             WidthRequest="17"
                                             HeightRequest="{Binding BarHeight}"
                                             HorizontalOptions="Center"
                                             VerticalOptions="End"
                                             Color="#01143D"
                                             CornerRadius="9" />
                                    <Label Grid.Row="1"
                                           Text="{Binding Day}"
                                           FontSize="10.5"
                                           TextColor="#667085"
                                           HorizontalTextAlignment="Center"
                                           Margin="0,4,0,0" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Grid>

            <!-- Category Breakdown -->
            <VerticalStackLayout Padding="24,0,24,20" Spacing="12">
                <Label Text="{Binding ChartTitle}"
                       TextColor="{StaticResource SpendyNavy}"
                       FontSize="17"
                       FontAttributes="Bold" />

                <!-- Empty State -->
                <Label Text="No spending data for this month yet."
                       IsVisible="{Binding ShowCategoryEmpty}"
                       TextColor="#667085"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       Margin="0,20" />

                <!-- Categories List -->
                <CollectionView ItemsSource="{Binding Categories}"
                                IsVisible="{Binding HasCategoryBreakdown}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                    StrokeThickness="0"
                                    Padding="16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="14">
                                    <!-- Icon -->
                                    <Border WidthRequest="40" HeightRequest="40"
                                            BackgroundColor="{StaticResource SpendyNavy}"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Icon}"
                                               FontSize="20"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>

                                    <!-- Category Name -->
                                    <Label Grid.Column="1"
                                           Text="{Binding Name}"
                                           TextColor="{StaticResource SpendyNavy}"
                                           FontAttributes="Bold"
                                           FontSize="15.5"
                                           VerticalOptions="Center" />

                                    <!-- Amount -->
                                    <Label Grid.Column="2"
                                           Text="{Binding FormattedAmount}"
                                           TextColor="{StaticResource SpendyNavy}"
                                           FontSize="15.5"
                                           FontAttributes="Medium"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>