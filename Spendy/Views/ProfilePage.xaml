<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Spendy.Controls"
             x:Class="Spendy.Views.ProfilePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource SpendyPageBg}">
    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,32">
                <!-- Dark header row -->
                <Grid Padding="16,12,16,18">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#01143D" Offset="0" />
                            <GradientStop Color="#0335A3" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Button Text="&#x2039;"
                                TextColor="White"
                                BackgroundColor="Transparent"
                                FontSize="26"
                                WidthRequest="44"
                                Clicked="OnBack" />
                        <Label Grid.Column="1"
                               Text="Profile"
                               TextColor="White"
                               FontFamily="OpenSansSemibold"
                               FontSize="20"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center" />
                        <Border Grid.Column="2"
                                WidthRequest="44"
                                HeightRequest="44"
                                StrokeThickness="0"
                                BackgroundColor="White"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <Ellipse />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenNotificationsCommand}" />
                            </Border.GestureRecognizers>
                            <Image Source="darkbluenotificon.png"
                                   WidthRequest="24"
                                   HeightRequest="24"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   InputTransparent="True" />
                        </Border>
                    </Grid>
                </Grid>

                <!-- White card: photo centered, name/handle below, then fields -->
                <Border Margin="20,-18,20,0"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="20,24,20,24">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="16">
                        <VerticalStackLayout Spacing="10"
                                             HorizontalOptions="Center">
                            <Grid WidthRequest="120"
                                  HeightRequest="120"
                                  HorizontalOptions="Center">
                                <Border WidthRequest="120"
                                        HeightRequest="120"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Start"
                                        StrokeThickness="0"
                                        BackgroundColor="#1A01143D">
                                    <Border.StrokeShape>
                                        <Ellipse />
                                    </Border.StrokeShape>
                                    <Image Source="{Binding ProfilePhoto}"
                                           Aspect="AspectFill" />
                                </Border>
                                <Border WidthRequest="36"
                                        HeightRequest="36"
                                        HorizontalOptions="End"
                                        VerticalOptions="End"
                                        Margin="0,0,-4,-4"
                                        BackgroundColor="White"
                                        StrokeThickness="0"
                                        Padding="7">
                                    <Border.StrokeShape>
                                        <Ellipse />
                                    </Border.StrokeShape>
                                    <Image Source="uploadphotoicon.png"
                                           Aspect="AspectFit">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnChangePhoto" />
                                        </Image.GestureRecognizers>
                                    </Image>
                                </Border>
                            </Grid>

                            <Label Text="{Binding Name}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="22"
                                   TextColor="{StaticResource SpendyNavy}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding Handle}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="#667085"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#E6E8EC" />

                        <VerticalStackLayout Spacing="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Name"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="{StaticResource SpendyNavy}" />
                                <Border BackgroundColor="#F1F3F5"
                                        StrokeThickness="0"
                                        Padding="14,0"
                                        HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10"
                                          VerticalOptions="Center">
                                        <Entry Text="{Binding Name, Mode=TwoWay}"
                                               BackgroundColor="Transparent"
                                               TextColor="#0B1B3A" />
                                        <Image Grid.Column="1"
                                               Source="editicon.png"
                                               WidthRequest="18"
                                               HeightRequest="18"
                                               Aspect="AspectFit" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Email"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="{StaticResource SpendyNavy}" />
                                <Border BackgroundColor="#F1F3F5"
                                        StrokeThickness="0"
                                        Padding="14,0"
                                        HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10"
                                          VerticalOptions="Center">
                                        <Entry Text="{Binding Email, Mode=TwoWay}"
                                               Keyboard="Email"
                                               BackgroundColor="Transparent"
                                               TextColor="#0B1B3A" />
                                        <Image Grid.Column="1"
                                               Source="editicon.png"
                                               WidthRequest="18"
                                               HeightRequest="18"
                                               Aspect="AspectFit" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Phone"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="{StaticResource SpendyNavy}" />
                                <Border BackgroundColor="#F1F3F5"
                                        StrokeThickness="0"
                                        Padding="14,0"
                                        HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10"
                                          VerticalOptions="Center">
                                        <Entry Text="{Binding Phone, Mode=TwoWay}"
                                               Keyboard="Telephone"
                                               BackgroundColor="Transparent"
                                               TextColor="#0B1B3A" />
                                        <Image Grid.Column="1"
                                               Source="editicon.png"
                                               WidthRequest="18"
                                               HeightRequest="18"
                                               Aspect="AspectFit" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Birthday"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="{StaticResource SpendyNavy}" />
                                <Border BackgroundColor="#F1F3F5"
                                        StrokeThickness="0"
                                        Padding="14,0"
                                        HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <DatePicker Date="{Binding BirthdayDate, Mode=TwoWay}"
                                                Format="MMMM dd, yyyy"
                                                TextColor="#0B1B3A"
                                                VerticalOptions="Center"
                                                MaximumDate="2099-12-31"
                                                MinimumDate="1920-01-01" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Gender"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="{StaticResource SpendyNavy}" />
                                <Border BackgroundColor="#F1F3F5"
                                        StrokeThickness="0"
                                        Padding="12,0"
                                        HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Picker Title="Select gender"
                                            ItemsSource="{Binding GenderOptions}"
                                            SelectedItem="{Binding Gender}"
                                            TextColor="#0B1B3A"
                                            TitleColor="#667085"
                                            VerticalOptions="Center" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Address"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="{StaticResource SpendyNavy}" />
                                <Border BackgroundColor="#F1F3F5"
                                        StrokeThickness="0"
                                        Padding="12,0"
                                        HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="10"
                                          VerticalOptions="Center">
                                        <Image Source="locpinicon.png"
                                               WidthRequest="18"
                                               HeightRequest="18"
                                               Aspect="AspectFit" />
                                        <Entry Grid.Column="1"
                                               Text="{Binding Address, Mode=TwoWay}"
                                               BackgroundColor="Transparent"
                                               TextColor="#0B1B3A" />
                                        <Image Grid.Column="2"
                                               Source="editicon.png"
                                               WidthRequest="18"
                                               HeightRequest="18"
                                               Aspect="AspectFit" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <Button Text="Save"
                                Command="{Binding SaveCommand}"
                                BackgroundColor="#0335A3"
                                TextColor="White"
                                FontFamily="OpenSansSemibold"
                                FontSize="16"
                                CornerRadius="22"
                                HeightRequest="50"
                                Margin="0,8,0,0" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <controls:SpendyTabBar Grid.Row="1"
                               SelectedIndex="3"
                               ShowTabBar="True" />
    </Grid>
</ContentPage>
