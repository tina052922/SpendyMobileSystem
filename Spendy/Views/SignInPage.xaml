<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Spendy.ViewModels"
             x:Class="Spendy.Views.SignInPage"
             x:DataType="vm:SignInViewModel"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F3F4F6">
    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0"
              Padding="24,56,24,28"
              MinimumHeightRequest="180"
              BackgroundColor="#001F54">
            <Label Text="Welcome Back!"
                   FontFamily="OpenSansSemibold"
                   FontSize="30"
                   TextColor="White"
                   HorizontalOptions="Start"
                   VerticalOptions="Start" />
        </Grid>

        <ScrollView Grid.Row="1" Margin="0,-20,0,0">
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="24,28,24,36">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24,24,0,0" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="18">
                    <Label Text="Email"
                           TextColor="#0F172A"
                           FontFamily="OpenSansSemibold"
                           FontSize="14" />
                    <Border BackgroundColor="White"
                            Stroke="#D1D5DB"
                            StrokeThickness="1"
                            Padding="14,0"
                            HeightRequest="50">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry Placeholder="Enter your email"
                               Keyboard="Email"
                               Text="{Binding Email}"
                               BackgroundColor="Transparent"
                               TextColor="#0F172A"
                               PlaceholderColor="#9CA3AF"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="Password"
                           TextColor="#0F172A"
                           FontFamily="OpenSansSemibold"
                           FontSize="14" />
                    <Border BackgroundColor="White"
                            Stroke="#D1D5DB"
                            StrokeThickness="1"
                            HeightRequest="50"
                            Padding="12,0,10,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                            <Entry x:Name="PasswordEntry"
                                   Grid.Column="0"
                                   Placeholder="Password"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   TextColor="#0F172A"
                                   PlaceholderColor="#9CA3AF"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTogglePasswordEye" />
                                </Border.GestureRecognizers>
                                <Image x:Name="PasswordEyeImage"
                                       Source="unhide.png"
                                       Aspect="AspectFit"
                                       WidthRequest="22"
                                       HeightRequest="22"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       InputTransparent="True" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                        <HorizontalStackLayout Spacing="8">
                            <CheckBox x:Name="RememberCheck" Color="#2563EB" />
                            <Label Text="Remember me"
                                   TextColor="#374151"
                                   VerticalOptions="Center"
                                   FontSize="14" />
                        </HorizontalStackLayout>
                        <Label Grid.Column="1"
                               Text="Forgot password"
                               TextColor="#0F172A"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnForgot" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <Button Text="Sign in"
                            BackgroundColor="#001F54"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            CornerRadius="14"
                            HeightRequest="52"
                            Margin="0,8,0,0"
                            Command="{Binding SignInCommand}" />

                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10" Margin="0,4">
                        <BoxView Grid.Column="0" HeightRequest="1" Color="#E5E7EB" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Or" TextColor="#9CA3AF" FontSize="13" />
                        <BoxView Grid.Column="2" HeightRequest="1" Color="#E5E7EB" VerticalOptions="Center" />
                    </Grid>

                    <Button Text="Sign in with Google"
                            ImageSource="google.png"
                            ContentLayout="Left,12"
                            BackgroundColor="White"
                            TextColor="#0F172A"
                            BorderColor="#D1D5DB"
                            BorderWidth="1"
                            CornerRadius="12"
                            FontSize="15"
                            HeightRequest="52"
                            Clicked="OnGoogle" />

                    <Label HorizontalTextAlignment="Center"
                           FontSize="14"
                           Margin="0,8,0,0"
                           TextColor="#6B7280">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Don't have an account? " />
                                <Span Text="Sign up"
                                      TextColor="#2563EB"
                                      FontAttributes="Bold">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignUp" />
                                    </Span.GestureRecognizers>
                                </Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>
