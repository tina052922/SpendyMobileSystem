<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Spendy.ViewModels"
             x:Class="Spendy.Views.AddSavingPlanPage"
             x:Name="PageRoot"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#01143D">
    <Grid RowDefinitions="Auto,*">
        <!-- Header (same structure as Add Transaction — no extra gradient layer) -->
        <Grid Grid.Row="0" Padding="16,12,16,18" RowDefinitions="Auto,Auto" RowSpacing="10">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                <Border WidthRequest="44"
                        HeightRequest="44"
                        StrokeThickness="0"
                        BackgroundColor="#1AFFFFFF">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Image Source="{Binding ProfilePhoto}"
                           Aspect="AspectFill" />
                </Border>
                <Border Grid.Column="2"
                        WidthRequest="44"
                        HeightRequest="44"
                        StrokeThickness="0"
                        BackgroundColor="Transparent"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                    </Border.GestureRecognizers>
                    <Image Source="darkbluenotificon.png"
                           WidthRequest="24"
                           HeightRequest="24"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           InputTransparent="True" />
                </Border>
            </Grid>
            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
                <Button Text="&#x2039;"
                        FontSize="26"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        WidthRequest="44"
                        Clicked="OnBack" />
                <Label Grid.Column="1"
                       Text="Add Savings Plan"
                       TextColor="White"
                       FontFamily="OpenSansSemibold"
                       FontSize="20"
                       HorizontalTextAlignment="Center"
                       VerticalOptions="Center" />
                <Grid Grid.Column="2"
                      WidthRequest="44"
                      HeightRequest="44" />
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="{StaticResource SpendyDarkSheet}"
                StrokeThickness="0"
                Margin="0,-16,0,0"
                Padding="16,18,16,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28,28,0,0" />
            </Border.StrokeShape>
            <ScrollView Margin="0,0,2,0">
                <VerticalStackLayout Spacing="16" Padding="0,0,0,18">
                    <Border StrokeThickness="0"
                            BackgroundColor="{StaticResource SpendyDarkInput}"
                            Padding="16,0"
                            HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22" />
                        </Border.StrokeShape>
                        <Entry Placeholder="Plan name"
                               PlaceholderColor="{StaticResource SpendyDarkPlaceholder}"
                               Text="{Binding PlanName, Mode=TwoWay}"
                               TextColor="{StaticResource SpendyDarkLabel}"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center" />
                    </Border>

                    <Grid>
                        <Border StrokeThickness="0"
                                BackgroundColor="{StaticResource SpendyDarkInput}"
                                Padding="16,0,48,0"
                                HeightRequest="54">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <Entry Placeholder="Amount"
                                   Keyboard="Numeric"
                                   PlaceholderColor="{StaticResource SpendyDarkPlaceholder}"
                                   Text="{Binding TargetAmountText, Mode=TwoWay}"
                                   TextColor="{StaticResource SpendyDarkLabel}"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center" />
                        </Border>
                        <Border WidthRequest="40"
                                HeightRequest="40"
                                HorizontalOptions="End"
                                VerticalOptions="Center"
                                Margin="0,0,10,0"
                                BackgroundColor="#0E1F3A"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <Ellipse />
                            </Border.StrokeShape>
                            <Label Text="₱"
                                   TextColor="White"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   InputTransparent="True" />
                        </Border>
                    </Grid>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Select Date"
                               TextColor="{StaticResource SpendyDarkLabel}"
                               FontSize="14"
                               FontFamily="OpenSansSemibold" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Text="Start Date"
                                    Command="{Binding SelectStartModeCommand}"
                                    BackgroundColor="{Binding StartToggleBg}"
                                    TextColor="White"
                                    FontFamily="OpenSansSemibold"
                                    CornerRadius="22"
                                    HeightRequest="48" />
                            <Button Grid.Column="1"
                                    Text="End Date"
                                    Command="{Binding SelectEndModeCommand}"
                                    BackgroundColor="{Binding EndToggleBg}"
                                    TextColor="White"
                                    FontFamily="OpenSansSemibold"
                                    CornerRadius="22"
                                    HeightRequest="48" />
                        </Grid>

                        <Border BackgroundColor="{StaticResource SpendyDarkInput}"
                                StrokeThickness="0"
                                Padding="12,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Button Text="&#x2039;"
                                            Command="{Binding PrevMonthCommand}"
                                            BackgroundColor="Transparent"
                                            TextColor="White"
                                            FontSize="22"
                                            WidthRequest="44"
                                            Padding="0" />
                                    <Label Grid.Column="1"
                                           Text="{Binding CalendarTitle}"
                                           TextColor="{StaticResource SpendyDarkLabel}"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="16"
                                           HorizontalTextAlignment="Center"
                                           VerticalOptions="Center" />
                                    <Button Grid.Column="2"
                                            Text="&#x203A;"
                                            Command="{Binding NextMonthCommand}"
                                            BackgroundColor="Transparent"
                                            TextColor="White"
                                            FontSize="22"
                                            WidthRequest="44"
                                            Padding="0" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="0">
                                    <Label Text="Sun" FontSize="11" TextColor="{StaticResource SpendyDarkMuted}" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="1" Text="Mon" FontSize="11" TextColor="{StaticResource SpendyDarkMuted}" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="2" Text="Tue" FontSize="11" TextColor="{StaticResource SpendyDarkMuted}" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="3" Text="Wed" FontSize="11" TextColor="{StaticResource SpendyDarkMuted}" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="4" Text="Thu" FontSize="11" TextColor="{StaticResource SpendyDarkMuted}" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="5" Text="Fri" FontSize="11" TextColor="{StaticResource SpendyDarkMuted}" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="6" Text="Sat" FontSize="11" TextColor="{StaticResource SpendyDarkMuted}" HorizontalTextAlignment="Center" />
                                </Grid>
                                <CollectionView ItemsSource="{Binding CalendarDays}"
                                                SelectionMode="None"
                                                HeightRequest="252">
                                    <CollectionView.ItemsLayout>
                                        <GridItemsLayout Orientation="Vertical"
                                                         Span="7"
                                                         HorizontalItemSpacing="2"
                                                         VerticalItemSpacing="4" />
                                    </CollectionView.ItemsLayout>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CalendarDayCell">
                                            <Button Text="{Binding DayText}"
                                                    TextColor="{Binding TextColor}"
                                                    BackgroundColor="{Binding CellBackground}"
                                                    FontSize="14"
                                                    HeightRequest="40"
                                                    CornerRadius="20"
                                                    Padding="0"
                                                    Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectDayCommand}"
                                                    CommandParameter="{Binding .}" />
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Duration"
                               TextColor="{StaticResource SpendyDarkLabel}"
                               FontSize="14"
                               FontFamily="OpenSansSemibold" />
                        <Border StrokeThickness="0"
                                BackgroundColor="{StaticResource SpendyDarkInput}"
                                Padding="16,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <Label Text="{Binding DurationText}"
                                   TextColor="{StaticResource SpendyDarkSubtext}"
                                   FontSize="16" />
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Save Plan"
                            Command="{Binding CreateCommand}"
                            BackgroundColor="{StaticResource SpendyBlueDeep}"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            CornerRadius="26"
                            HeightRequest="54"
                            Margin="0,8,0,0" />
                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>
