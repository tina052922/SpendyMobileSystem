<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Spendy.ViewModels"
             x:Class="Spendy.Views.ForgotPasswordRequestPage"
             x:DataType="vm:ForgotPasswordRequestViewModel"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F3F4F6">
    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0"
              Padding="24,56,24,28"
              MinimumHeightRequest="180"
              BackgroundColor="#001F54">
            <VerticalStackLayout Spacing="6">
                <Label Text="Forgot Password"
                       FontFamily="OpenSansSemibold"
                       FontSize="30"
                       TextColor="White" />
                <Label Text="Enter your email to receive a reset code."
                       FontSize="14"
                       TextColor="#E5E7EB" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1" Margin="0,-20,0,0">
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="24,28,24,36">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24,24,0,0" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="18">
                    <Label Text="Email"
                           TextColor="#0F172A"
                           FontFamily="OpenSansSemibold"
                           FontSize="14" />
                    <Border BackgroundColor="White"
                            Stroke="#D1D5DB"
                            StrokeThickness="1"
                            Padding="14,0"
                            HeightRequest="50">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry Placeholder="Enter your email"
                               Keyboard="Email"
                               Text="{Binding Email}"
                               BackgroundColor="Transparent"
                               TextColor="#0F172A"
                               PlaceholderColor="#9CA3AF"
                               VerticalOptions="Center" />
                    </Border>

                    <Button Text="Send reset code"
                            BackgroundColor="#001F54"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            CornerRadius="14"
                            HeightRequest="52"
                            Margin="0,8,0,0"
                            Command="{Binding SendResetCommand}" />

                    <Button Text="Back to sign in"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontFamily="OpenSansSemibold"
                            FontSize="14"
                            Clicked="OnBack" />
                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>

