<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Spendy.Views.DashboardView">
    <Grid BackgroundColor="{StaticResource SpendyPageBg}">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="0,0,0,120">
                <!-- Header: avatar + notification, then centered balance -->
              
                <Grid Padding="16,12,16,44"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="10"
                      HeightRequest="210"
                      BackgroundColor="#01143D">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                        <Border WidthRequest="44"
                                HeightRequest="44"
                                StrokeThickness="0"
                                BackgroundColor="Transparent"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <Ellipse />
                            </Border.StrokeShape>
                            <Image Source="{Binding ProfilePhoto}" Aspect="AspectFill" />
                        </Border>

                        <Border Grid.Column="2"
                                WidthRequest="44"
                                HeightRequest="44"
                                BackgroundColor="Transparent"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                HorizontalOptions="End">
                            <Border.StrokeShape>
                                <Ellipse />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenNotificationsCommand}" />
                            </Border.GestureRecognizers>
                            <Image Source="whitenotificon.png"
                                   Aspect="AspectFit"
                                   WidthRequest="24"
                                   HeightRequest="24"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   InputTransparent="True" />
                        </Border>
                    </Grid>

                    <VerticalStackLayout Grid.Row="1" Spacing="2" HorizontalOptions="Center">
                        <VerticalStackLayout Grid.Row="1"
                                         Spacing="2"
                                         HorizontalOptions="Center"
                                         VerticalOptions="CenterAndExpand">
                            <Label Text="Available balance"
                               TextColor="#B3FFFFFF"
                               FontSize="14"
                               HorizontalTextAlignment="Center" />
                            <Label Text="{Binding AvailableBalance}"
                               TextColor="White"
                               FontFamily="OpenSansSemibold"
                               FontSize="44"
                               HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- Main content card -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Margin="0,-28,0,0"
                        ZIndex="1"
                        Padding="24,22,24,22">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="34,34,0,0" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Text="Expenses"
                                    Command="{Binding SelectExpenseCommand}"
                                    TextColor="White"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="18"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    BackgroundColor="{Binding ExpenseButtonBackground}" />
                            <Button Grid.Column="1"
                                    Text="Income"
                                    Command="{Binding SelectIncomeCommand}"
                                    TextColor="White"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="18"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    BackgroundColor="{Binding IncomeButtonBackground}" />
                        </Grid>

                        <Border BackgroundColor="#F1F3F5"
                                StrokeThickness="0"
                                Padding="16,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding SummaryLabel}"
                                       TextColor="#475467"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding SummaryAmount}"
                                       TextColor="{Binding SummaryColor}"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border BackgroundColor="{StaticResource SpendyNavy}"
                                StrokeThickness="0"
                                Padding="16,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding DateLabel}"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       VerticalOptions="Center" />
                                <Border Grid.Column="1"
                                        WidthRequest="36"
                                        HeightRequest="36"
                                        Stroke="#BFD0E3"
                                        StrokeThickness="1.2"
                                        BackgroundColor="{StaticResource SpendyNavy}">
                                    <Border.StrokeShape>
                                        <Ellipse />
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenMonthlyViewCommand}" />
                                    </Border.GestureRecognizers>
                                    <Image Source="calendar.png"
                                           WidthRequest="18"
                                           HeightRequest="18"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <Grid BackgroundColor="Transparent">
                            <VerticalStackLayout IsVisible="{Binding ShowEmptyState}"
                                                 Padding="0,24,0,40"
                                                 Spacing="10"
                                                 HorizontalOptions="Fill">
                                <Label Text="No transactions yet"
                                       TextColor="{StaticResource SpendyNavy}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="18"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Tap the + button to add your first transaction."
                                       TextColor="{StaticResource SpendyMutedText}"
                                       FontSize="14"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <CollectionView ItemsSource="{Binding Transactions}"
                                            IsVisible="{Binding HasTransactions}"
                                            SelectionMode="None">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#F8FAFC"
                                                StrokeThickness="0"
                                                Padding="12">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="16" />
                                            </Border.StrokeShape>
                                            <Border.Shadow>
                                                <Shadow Brush="#1A000000" Offset="0,2" Radius="10" Opacity="0.35" />
                                            </Border.Shadow>
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <Border WidthRequest="36"
                                                        HeightRequest="36"
                                                        BackgroundColor="{StaticResource SpendyNavy}"
                                                        StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="10" />
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding Icon}"
                                                           FontSize="18"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />
                                                </Border>
                                                <Label Grid.Column="1"
                                                       Text="{Binding Category}"
                                                       TextColor="{StaticResource SpendyNavy}"
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center" />
                                                <VerticalStackLayout Grid.Column="2" HorizontalOptions="End">
                                                    <Label Text="{Binding FormattedAmount}"
                                                           TextColor="{Binding AmountColor}"
                                                           FontSize="14"
                                                           HorizontalTextAlignment="End" />
                                                    <Label Text="{Binding Time}"
                                                           TextColor="{StaticResource SpendyMutedText}"
                                                           FontSize="14"
                                                           HorizontalTextAlignment="End" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Button Text="+"
                FontSize="28"
                TextColor="White"
                WidthRequest="56"
                HeightRequest="56"
                CornerRadius="28"
                BackgroundColor="{StaticResource SpendyAccent}"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,24,96"
                Command="{Binding AddTransactionCommand}" />

        <!-- Monthly daily breakdown overlay (opened by calendar icon) -->
        <Grid IsVisible="{Binding IsMonthlyViewOpen}"
              BackgroundColor="#80000000"
              Padding="18"
              ZIndex="99">
            <Border BackgroundColor="{StaticResource SpendyNavy}"
                    StrokeThickness="0"
                    Padding="18"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="360">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Button Text="‹"
                                WidthRequest="40"
                                HeightRequest="40"
                                CornerRadius="20"
                                BackgroundColor="#1AFFFFFF"
                                TextColor="White"
                                FontSize="18"
                                Command="{Binding PrevMonthCommand}" />

                        <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                            <Label Text="{Binding MonthlyMonthLabel}"
                                   TextColor="White"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   HorizontalTextAlignment="Center" />
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="{Binding TopSpendingDayHint}" TextColor="#D0D5DD" FontSize="11" />
                                <Label Text="{Binding TopIncomeDayHint}" TextColor="#D0D5DD" FontSize="11" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <Button Grid.Column="2"
                                Text="›"
                                WidthRequest="40"
                                HeightRequest="40"
                                CornerRadius="20"
                                BackgroundColor="#1AFFFFFF"
                                TextColor="White"
                                FontSize="18"
                                Command="{Binding NextMonthCommand}" />
                    </Grid>

                    <!-- Month/year picker (uses DatePicker; day ignored) -->
                    <Border BackgroundColor="#1AFFFFFF"
                            StrokeThickness="0"
                            Padding="12,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <DatePicker Date="{Binding MonthlySelectedDate}"
                                    TextColor="White"
                                    BackgroundColor="Transparent"
                                    Format="MMMM yyyy"
                                    HorizontalOptions="Center" />
                    </Border>

                    <Label Text="Daily activity"
                           TextColor="White"
                           FontFamily="OpenSansSemibold"
                           FontSize="13" />

                    <!-- Calendar grid (Sun → Sat) -->
                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="10">
                        <Grid Grid.Row="0"
                              ColumnDefinitions="*,*,*,*,*,*,*"
                              ColumnSpacing="6">
                            <Label Grid.Column="0" Text="SUN" TextColor="#D0D5DD" FontSize="10" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="MON" TextColor="#D0D5DD" FontSize="10" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="TUE" TextColor="#D0D5DD" FontSize="10" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="WED" TextColor="#D0D5DD" FontSize="10" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="THU" TextColor="#D0D5DD" FontSize="10" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="FRI" TextColor="#D0D5DD" FontSize="10" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="6" Text="SAT" TextColor="#D0D5DD" FontSize="10" HorizontalTextAlignment="Center" />
                        </Grid>

                        <CollectionView Grid.Row="1"
                                        ItemsSource="{Binding MonthlyDays}"
                                        SelectionMode="None"
                                        HeightRequest="360">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical"
                                                 Span="7"
                                                 HorizontalItemSpacing="8"
                                                 VerticalItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#0B2A66"
                                            Stroke="{Binding BorderColor}"
                                            StrokeThickness="{Binding BorderThickness}"
                                            Padding="10">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>

                                        <Grid RowDefinitions="Auto,Auto,Auto"
                                              RowSpacing="6">
                                            <Label Text="{Binding DayLabel}"
                                                   TextColor="White"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="12" />

                                            <HorizontalStackLayout Grid.Row="1"
                                                                   Spacing="6"
                                                                   IsVisible="{Binding HasExpense}">
                                                <BoxView WidthRequest="7"
                                                         HeightRequest="7"
                                                         CornerRadius="3.5"
                                                         BackgroundColor="{Binding ExpenseDotColor}"
                                                         VerticalOptions="Center" />
                                                <Label Text="{Binding ExpenseText}"
                                                       TextColor="#D0D5DD"
                                                       FontSize="10"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1" />
                                            </HorizontalStackLayout>

                                            <HorizontalStackLayout Grid.Row="2"
                                                                   Spacing="6"
                                                                   IsVisible="{Binding HasIncome}">
                                                <BoxView WidthRequest="7"
                                                         HeightRequest="7"
                                                         CornerRadius="3.5"
                                                         BackgroundColor="{Binding IncomeDotColor}"
                                                         VerticalOptions="Center" />
                                                <Label Text="{Binding IncomeText}"
                                                       TextColor="#D0D5DD"
                                                       FontSize="10"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1" />
                                            </HorizontalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>

                    <Button Text="Close"
                            BackgroundColor="#1AFFFFFF"
                            TextColor="White"
                            CornerRadius="14"
                            HeightRequest="44"
                            Command="{Binding CloseMonthlyViewCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentView>
