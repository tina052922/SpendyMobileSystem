<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Spendy.ViewModels"
             x:Class="Spendy.Views.NotificationPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#01143D" Offset="0" />
            <GradientStop Color="#0335A3" Offset="1" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" Padding="16,12,16,18">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <Border WidthRequest="44"
                        HeightRequest="44"
                        StrokeThickness="0"
                        BackgroundColor="#1AFFFFFF">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Label Text="&#x2039;"
                           TextColor="White"
                           FontSize="28"
                           HorizontalOptions="Center"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBack" />
                        </Label.GestureRecognizers>
                    </Label>
                </Border>

                <Label Grid.Column="1"
                       Text="Notifications"
                       TextColor="White"
                       FontFamily="OpenSansSemibold"
                       FontSize="20"
                       HorizontalTextAlignment="Center"
                       VerticalOptions="Center" />

                <Border Grid.Column="2"
                        WidthRequest="44"
                        HeightRequest="44"
                        StrokeThickness="0"
                        BackgroundColor="#1AFFFFFF"
                        IsVisible="{Binding HasAlerts}">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Label Text="{Binding BadgeCount}"
                           TextColor="White"
                           FontFamily="OpenSansSemibold"
                           FontSize="14"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="#1B2B42"
                StrokeThickness="0"
                Margin="0,-20,0,0"
                Padding="16,20,16,24">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28,28,0,0" />
            </Border.StrokeShape>

            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24"
                                         Spacing="8"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                        <Label Text="No alerts right now"
                               TextColor="#BFD0E3"
                               FontFamily="OpenSansSemibold"
                               FontSize="16"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Savings reminders and budget tips will appear here."
                               TextColor="#62738A"
                               FontSize="13"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:NotificationItemVm">
                        <Border BackgroundColor="#1E3050"
                                StrokeThickness="0"
                                Padding="0"
                                Margin="0,0,0,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="5,Auto,*"
                                  ColumnSpacing="0">
                                <BoxView Grid.Column="0"
                                         BackgroundColor="{Binding AccentColor}" />
                                <Border Grid.Column="1"
                                        WidthRequest="46"
                                        HeightRequest="46"
                                        BackgroundColor="#243652"
                                        StrokeThickness="0"
                                        Margin="14,14,0,14"
                                        VerticalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding IconGlyph}"
                                           FontSize="22"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="2"
                                                     Spacing="3"
                                                     VerticalOptions="Center"
                                                     Margin="12,14,14,14">
                                    <Label Text="{Binding Title}"
                                           TextColor="White"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="13" />
                                    <Label Text="{Binding Message}"
                                           TextColor="#BFD0E3"
                                           FontSize="12"
                                           LineBreakMode="WordWrap" />
                                    <Label Text="{Binding TimeText}"
                                           TextColor="#62738A"
                                           FontSize="11"
                                           Margin="0,4,0,0" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>
    </Grid>
</ContentPage>
