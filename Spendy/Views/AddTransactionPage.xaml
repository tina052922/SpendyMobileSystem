<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:Spendy.Converters"
             x:Class="Spendy.Views.AddTransactionPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">
    <ContentPage.Resources>
        <conv:BoolToDoubleConverter x:Key="CatSelStroke" TrueValue="2.5" FalseValue="0" />
    </ContentPage.Resources>
    <ContentPage.Background>
        <SolidColorBrush Color="#01143D" />
    </ContentPage.Background>
    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,12,16,18" RowDefinitions="Auto,Auto" RowSpacing="10">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                <Border WidthRequest="44"
                        HeightRequest="44"
                        StrokeThickness="0"
                        BackgroundColor="#1AFFFFFF">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Image Source="{Binding ProfilePhoto}" Aspect="AspectFill" />
                </Border>
                <Border Grid.Column="2"
                        WidthRequest="44"
                        HeightRequest="44"
                        StrokeThickness="0"
                        BackgroundColor="Transparent"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenNotificationsCommand}" />
                    </Border.GestureRecognizers>
                    <Image Source="whitenotificon.png"
                           WidthRequest="24"
                           HeightRequest="24"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           InputTransparent="True" />
                </Border>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
                <Button Text="&#x2039;"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        FontSize="26"
                        WidthRequest="44"
                        Clicked="OnBack" />
                <Label Grid.Column="1"
                       Text="Add Transaction"
                       TextColor="White"
                       FontFamily="OpenSansSemibold"
                       FontSize="20"
                       HorizontalTextAlignment="Center"
                       VerticalOptions="Center" />
                
            </Grid>
        </Grid>

        <!-- Main dark content area -->
        <Border Grid.Row="1"
                BackgroundColor="#1B2B42"
                StrokeThickness="0"
                Margin="0,-16,0,0"
                Padding="16,18,16,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28,28,0,0" />
            </Border.StrokeShape>

            <!-- Margin clears vertical scrollbar overlap on narrow layouts -->
            <ScrollView Margin="0,0,2,0">
                <VerticalStackLayout Spacing="16" Padding="0,0,0,18">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="Expenses"
                                Command="{Binding SelectExpenseCommand}"
                                TextColor="White"
                                FontFamily="OpenSansSemibold"
                                FontSize="18"
                                CornerRadius="26"
                                HeightRequest="52"
                                BackgroundColor="{Binding ExpenseAccentBackground}" />
                        <Button Grid.Column="1"
                                Text="Income"
                                Command="{Binding SelectIncomeCommand}"
                                TextColor="White"
                                FontFamily="OpenSansSemibold"
                                FontSize="18"
                                CornerRadius="26"
                                HeightRequest="52"
                                BackgroundColor="{Binding IncomeAccentBackground}" />
                    </Grid>

                    <Grid>
                        <Border BackgroundColor="#2A3B55"
                                StrokeThickness="0"
                                Padding="16,0"
                                HeightRequest="54">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <Entry Placeholder="Amount"
                                   PlaceholderColor="#8FA1B5"
                                   Text="{Binding AmountText}"
                                   TextColor="White"
                                   Keyboard="Numeric"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center" />
                        </Border>
                        <Border WidthRequest="40"
                                HeightRequest="40"
                                HorizontalOptions="End"
                                VerticalOptions="Center"
                                Margin="0,0,10,0"
                                BackgroundColor="#0E1F3A"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <Ellipse />
                            </Border.StrokeShape>
                            <Label Text="₱"
                                   TextColor="White"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <Border BackgroundColor="#2A3B55"
                            StrokeThickness="0"
                            Padding="16,0"
                            HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22" />
                        </Border.StrokeShape>
                        <Entry Placeholder="Notes"
                               PlaceholderColor="#8FA1B5"
                               Text="{Binding Notes}"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="Category"
                           TextColor="White"
                           FontSize="14"
                           FontFamily="OpenSansSemibold" />

                    <CollectionView ItemsSource="{Binding ExpensePicker}"
                                      SelectedItem="{Binding SelectedExpenseCategory, Mode=TwoWay}"
                                      SelectionMode="Single"
                                      IsVisible="{Binding IsExpenseMode}">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="5"
                                             HorizontalItemSpacing="10"
                                             VerticalItemSpacing="16" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Padding="2,2"
                                                     Spacing="8"
                                                     HorizontalOptions="Fill">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup Name="CommonStates">
                                            <VisualState Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <Border HorizontalOptions="Center"
                                            WidthRequest="72"
                                            HeightRequest="72"
                                            BackgroundColor="#2A3B55"
                                            Stroke="{StaticResource SpendyAccent}"
                                            StrokeThickness="{Binding IsSelected, Converter={StaticResource CatSelStroke}}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="22" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Icon}"
                                               FontSize="32"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                    <Label Text="{Binding Name}"
                                           TextColor="#D6E3F2"
                                           FontSize="11"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <CollectionView ItemsSource="{Binding IncomePicker}"
                                    SelectedItem="{Binding SelectedIncomeCategory, Mode=TwoWay}"
                                    SelectionMode="Single"
                                    IsVisible="{Binding IsIncomeMode}">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="5"
                                             HorizontalItemSpacing="10"
                                             VerticalItemSpacing="16" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Padding="2,2"
                                                     Spacing="8"
                                                     HorizontalOptions="Fill">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup Name="CommonStates">
                                            <VisualState Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <Border HorizontalOptions="Center"
                                            WidthRequest="72"
                                            HeightRequest="72"
                                            BackgroundColor="#2A3B55"
                                            Stroke="{StaticResource SpendyAccent}"
                                            StrokeThickness="{Binding IsSelected, Converter={StaticResource CatSelStroke}}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="22" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Icon}"
                                               FontSize="32"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                    <Label Text="{Binding Name}"
                                           TextColor="#D6E3F2"
                                           FontSize="11"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="Select Date"
                           TextColor="White"
                           FontSize="14"
                           FontFamily="OpenSansSemibold" />

                    <Border BackgroundColor="#2A3B55"
                            StrokeThickness="0"
                            Padding="12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="12" HorizontalOptions="Center">
                                <HorizontalStackLayout Grid.Column="0" Spacing="6">
                                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" BackgroundColor="#0335A3" VerticalOptions="Center" />
                                    <Label Text="Added" TextColor="#BFD0E3" FontSize="12" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Column="1" Spacing="6">
                                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" BackgroundColor="#00B2FF" VerticalOptions="Center" />
                                    <Label Text="Recurring" TextColor="#BFD0E3" FontSize="12" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Column="2" Spacing="6">
                                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" BackgroundColor="#62738A" VerticalOptions="Center" />
                                    <Label Text="Not Available" TextColor="#BFD0E3" FontSize="12" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Grid>
                            <FlexLayout x:Name="CalendarHost"
                                        Wrap="Wrap"
                                        JustifyContent="SpaceAround" />
                        </VerticalStackLayout>
                    </Border>

                    <Button Text="Save Transaction"
                            Command="{Binding SaveCommand}"
                            BackgroundColor="#0335A3"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            CornerRadius="26"
                            HeightRequest="54"
                            Margin="0,8,0,0" />
                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>
