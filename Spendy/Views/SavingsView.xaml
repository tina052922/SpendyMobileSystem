<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Spendy.Views.SavingsView">
    <Grid BackgroundColor="{StaticResource SpendyPageBg}">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="0,0,0,120">
                <Grid Padding="16,12,16,18">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#01143D" Offset="0" />
                            <GradientStop Color="#0335A3" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                        <HorizontalStackLayout Spacing="12">
                            <Border WidthRequest="44"
                                    HeightRequest="44"
                                    StrokeThickness="0"
                                    BackgroundColor="#1AFFFFFF"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <Ellipse />
                                </Border.StrokeShape>
                                <Image Source="{Binding ProfilePhoto}"
                                       Aspect="AspectFill" />
                            </Border>
                            <Label Text="Savings"
                                   TextColor="White"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="20"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Border Grid.Column="2"
                                WidthRequest="44"
                                HeightRequest="44"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <Ellipse />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenNotificationsCommand}" />
                            </Border.GestureRecognizers>
                            <Image Source="darkbluenotificon.png"
                                   WidthRequest="24"
                                   HeightRequest="24"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   InputTransparent="True" />
                        </Border>
                        <Label Grid.Column="3"
                               Text="Ended"
                               TextColor="{StaticResource SpendyRed}"
                               FontAttributes="Bold"
                               FontSize="13"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEndedTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Grid>

                <Grid Margin="24,-10,24,0">
                    <VerticalStackLayout IsVisible="{Binding ShowEmptyState}"
                                         Padding="0,32,0,24"
                                         Spacing="12">
                        <Label Text="No saving goals yet"
                               TextColor="{StaticResource SpendyNavy}"
                               FontFamily="OpenSansSemibold"
                               FontSize="18"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Tap + to create your first plan."
                               TextColor="#99011D3D"
                               FontSize="14"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    <CollectionView ItemsSource="{Binding Plans}"
                                    IsVisible="{Binding HasPlans}"
                                    SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                    StrokeThickness="0"
                                    Padding="18">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#1A000000" Offset="0,2" Radius="12" Opacity="0.35" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPlanTapped" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Name}"
                                               TextColor="{StaticResource SpendyNavy}"
                                               FontAttributes="Bold"
                                               FontSize="16"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="Edit"
                                               TextColor="{StaticResource SpendyAccent}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="13"
                                               VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnEditClicked" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>
                                    <Label Text="{Binding AmountLine}"
                                           TextColor="{StaticResource SpendyNavy}"
                                           FontSize="15"
                                           FontAttributes="Bold" />
                                    <ProgressBar Progress="{Binding Progress}"
                                                 ProgressColor="{StaticResource SpendyAccentSoft}"
                                                 BackgroundColor="#D0D5DD"
                                                 HeightRequest="6" />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding TargetDate, StringFormat='Target Date: {0}'}"
                                               FontSize="12"
                                               TextColor="#667085" />
                                        <Label Grid.Column="1"
                                               FontSize="12"
                                               TextColor="#667085"
                                               HorizontalTextAlignment="End">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding ProgressPercent, StringFormat='{0:F0}'}" />
                                                    <Span Text="% Complete" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <Button Text="+"
                FontSize="28"
                TextColor="White"
                WidthRequest="56"
                HeightRequest="56"
                CornerRadius="28"
                BackgroundColor="{StaticResource SpendyAccent}"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,24,110"
                Command="{Binding AddPlanCommand}" />
    </Grid>
</ContentView>
