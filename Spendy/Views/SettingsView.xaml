<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Spendy.Views.SettingsView">
    <ScrollView BackgroundColor="{StaticResource SpendyPageBg}">
        <VerticalStackLayout Padding="0,0,0,120" Spacing="0">

            <!-- Header -->
            <Grid Padding="24,52,24,24">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#01143D" Offset="0" />
                        <GradientStop Color="#0335A3" Offset="1" />
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <!-- Avatar -->
                    <Border WidthRequest="40"
                            HeightRequest="40"
                            StrokeThickness="2"
                            Stroke="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Image Source="profile_placeholder.png"
                               Aspect="AspectFill"
                               WidthRequest="40"
                               HeightRequest="40" />
                    </Border>

                    <Label Grid.Column="1"
                           Text="Settings"
                           TextColor="White"
                           FontFamily="OpenSansSemibold"
                           FontSize="24"
                           VerticalOptions="Center" />

                    <Border Grid.Column="2"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            WidthRequest="40"
                            HeightRequest="40"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <ImageButton Source="whitenotificon.png"
                                     BackgroundColor="Transparent"
                                     WidthRequest="22"
                                     HeightRequest="22"
                                     Aspect="AspectFit"
                                     Clicked="OnNotifications" />
                    </Border>
                </Grid>
            </Grid>

            <!-- Settings Cards -->
            <VerticalStackLayout Padding="20,20,20,0" Spacing="12">

                <!-- Profile Card -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Grid Padding="18,16" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnProfileTapped" />
                        </Grid.GestureRecognizers>
                        <Border BackgroundColor="#EEF3FF"
                                StrokeThickness="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Image Source="profileicon.png"
                                   WidthRequest="20"
                                   HeightRequest="20"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Column="1"
                               Text="Profile"
                               TextColor="{StaticResource SpendyNavy}"
                               FontFamily="OpenSansSemibold"
                               FontSize="15"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2"
                               Text="›"
                               TextColor="#98A2B3"
                               FontSize="22"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Language Card -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Grid Padding="18,16" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                        <Border BackgroundColor="#EEF3FF"
                                StrokeThickness="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Image Source="languageicon.png"
                                   WidthRequest="20"
                                   HeightRequest="20"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Column="1"
                               Text="Language"
                               TextColor="{StaticResource SpendyNavy}"
                               FontFamily="OpenSansSemibold"
                               FontSize="15"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2"
                               Text="English"
                               TextColor="#667085"
                               FontSize="14"
                               VerticalOptions="Center" />
                        <Label Grid.Column="3"
                               Text="›"
                               TextColor="#98A2B3"
                               FontSize="22"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Currency Card -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Grid Padding="18,16" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCurrencyTapped" />
                        </Grid.GestureRecognizers>
                        <Border BackgroundColor="#EEF3FF"
                                StrokeThickness="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Image Source="currencyicon.png"
                                   WidthRequest="20"
                                   HeightRequest="20"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Column="1"
                               Text="Currency"
                               TextColor="{StaticResource SpendyNavy}"
                               FontFamily="OpenSansSemibold"
                               FontSize="15"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2"
                               Text="{Binding SelectedCurrency}"
                               TextColor="#667085"
                               FontSize="14"
                               VerticalOptions="Center" />
                        <Label Grid.Column="3"
                               Text="›"
                               TextColor="#98A2B3"
                               FontSize="22"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Update Password Card -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="0">

                        <!-- Header row -->
                        <Grid Padding="18,16" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTogglePassword" />
                            </Grid.GestureRecognizers>
                            <Border BackgroundColor="#EEF3FF"
                                    StrokeThickness="0"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Image Source="passwordicon.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1"
                                   Text="Update Password"
                                   TextColor="{StaticResource SpendyNavy}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="15"
                                   VerticalOptions="Center" />
                            <Label x:Name="Chevron"
                                   Grid.Column="2"
                                   Text="›"
                                   TextColor="#98A2B3"
                                   FontSize="22"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Expanded password section -->
                        <VerticalStackLayout x:Name="PasswordFields"
                                             IsVisible="False"
                                             Padding="18,0,18,20"
                                             Spacing="14">

                            <!-- Subtitle -->
                            <Label Text="Change your password to update &amp; protect your Account"
                                   TextColor="{StaticResource SpendyAccent}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap" />

                            <!-- Current Password -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Current Password"
                                       TextColor="{StaticResource SpendyNavy}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13" />
                                <Border BackgroundColor="White"
                                        StrokeThickness="1.5"
                                        Stroke="#D0D9E8"
                                        Padding="14,0"
                                        HeightRequest="48">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                                        <Entry x:Name="CurrentPassword"
                                               IsPassword="True"
                                               Placeholder="Enter Current Password"
                                               PlaceholderColor="#B0BCCE"
                                               BackgroundColor="Transparent"
                                               TextColor="{StaticResource SpendyNavy}"
                                               HeightRequest="48" />
                                        <ImageButton Grid.Column="1"
                                                     Source="unhide.png"
                                                     BackgroundColor="Transparent"
                                                     WidthRequest="22"
                                                     HeightRequest="22"
                                                     Clicked="OnToggleCurrent" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- New Password -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="New Password"
                                       TextColor="{StaticResource SpendyNavy}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13" />
                                <Border BackgroundColor="White"
                                        StrokeThickness="1.5"
                                        Stroke="#D0D9E8"
                                        Padding="14,0"
                                        HeightRequest="48">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                                        <Entry x:Name="NewPassword"
                                               IsPassword="True"
                                               Placeholder="Enter New Password"
                                               PlaceholderColor="#B0BCCE"
                                               BackgroundColor="Transparent"
                                               TextColor="{StaticResource SpendyNavy}"
                                               HeightRequest="48" />
                                        <ImageButton Grid.Column="1"
                                                     Source="unhide.png"
                                                     BackgroundColor="Transparent"
                                                     WidthRequest="22"
                                                     HeightRequest="22"
                                                     Clicked="OnToggleNew" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Confirm Password -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Confirm Password"
                                       TextColor="{StaticResource SpendyNavy}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13" />
                                <Border BackgroundColor="White"
                                        StrokeThickness="1.5"
                                        Stroke="#D0D9E8"
                                        Padding="14,0"
                                        HeightRequest="48">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                                        <Entry x:Name="ConfirmPassword"
                                               IsPassword="True"
                                               Placeholder="Confirm Password"
                                               PlaceholderColor="#B0BCCE"
                                               BackgroundColor="Transparent"
                                               TextColor="{StaticResource SpendyNavy}"
                                               HeightRequest="48" />
                                        <ImageButton Grid.Column="1"
                                                     Source="unhide.png"
                                                     BackgroundColor="Transparent"
                                                     WidthRequest="22"
                                                     HeightRequest="22"
                                                     Clicked="OnToggleConfirm" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <Button Text="Update Password"
                                    BackgroundColor="{StaticResource SpendyAccent}"
                                    TextColor="White"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="15"
                                    CornerRadius="12"
                                    HeightRequest="50"
                                    Margin="0,4,0,0"
                                    Clicked="OnUpdatePassword" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Log Out Card -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Grid Padding="18,16" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogoutTapped" />
                        </Grid.GestureRecognizers>
                        <Border BackgroundColor="#FFF0EE"
                                StrokeThickness="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Image Source="logouticon.png"
                                   WidthRequest="20"
                                   HeightRequest="20"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Column="1"
                               Text="Log out"
                               TextColor="{StaticResource SpendyNavy}"
                               FontFamily="OpenSansSemibold"
                               FontSize="15"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2"
                               Text="›"
                               TextColor="#98A2B3"
                               FontSize="22"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentView>
